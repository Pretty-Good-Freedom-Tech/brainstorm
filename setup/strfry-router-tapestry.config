connectionTimeout = 20

streams {

    ## DCoSL: Decentralized Lists
    ## dedicated DCoSL relays
    dcosl {
        dir = "both"

        filter = { "kinds": [9998, 9999, 39998, 39999, 7], "limit": 5 }

        urls = [
            "wss://dcosl.brainstorm.world"
        ]
    }

    ## general purpose relays that might have DCoSL data but are not dedicated DCoSL relays
    ## don't upload kind 7 from these relays bc would be too many irrelevant events
    dcosl2 {
        dir = "down"

        filter = { "kinds": [9998, 9999, 39998, 39999], "limit": 5 }

        urls = [
            "wss://relay.damus.io"
        ]
    }

    ## Relays that maintain Trusted Lists
    trustedLists {
        dir = "both"

        filter = { "kinds": [30392, 30393, 30394, 30395], "limit": 5 }

        urls = [
            "wss://nip85.brainstorm.world",
            "wss://nip85.nostr1.com",
            "wss://nip85.grapevine.network"
        ]
    }
}
